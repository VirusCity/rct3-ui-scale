{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "vs2026-x86",
      "displayName": "VS 2026 — Win32 (x86)",
      "description": "Visual Studio 2026 generator, forced to 32-bit. Required for RCT3.",
      "generator": "Visual Studio 18 2026",
      "architecture": { "value": "Win32", "strategy": "set" },
      "binaryDir": "${sourceDir}/build"
    }
  ],
  "buildPresets": [
    {
      "name": "vs2026-x86-debug",
      "configurePreset": "vs2026-x86",
      "configuration": "Debug"
    },
    {
      "name": "vs2026-x86-release",
      "configurePreset": "vs2026-x86",
      "configuration": "Release"
    }
  ]
}
